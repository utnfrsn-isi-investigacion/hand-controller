{
  "esp32": {
    "ip": "esp32.local",
    "port": 1234,
    "connection_timeout": 5
  },
  "camera": {
    "index": 0,
    "width": 640,
    "height": 480
  },
  "hand_detection": {
    "max_hands": 2,
    "min_detection_confidence": 0.5,
    "min_tracking_confidence": 0.5,
    "open_threshold_ratio": 0.6,
    "index_orientation_threshold": 0.05
  },
  "display": {
    "show_overlays": true,
    "show_landmarks": true,
    "show_confidence": true,
    "show_fps": false,
    "window_name": "Hand Gesture Recognition",
    "left_hand_color": [0, 255, 0],
    "right_hand_color": [0, 0, 255],
    "text_scale": 1.0,
    "text_thickness": 2
  },
  "handler": {
    "buffer_size": 30,
    "refresh_interval": 0.5
  }
}
